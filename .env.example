PRICE_FORENSICS=0.02
PRICE_REPORT=0.03
MCP_DEXSCREENER_CMD=
MCP_HONEYPOT_CMD=
MCP_BLOCKSCOUT_CMD=
CACHE_TTL_MS=45000
