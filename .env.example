PORT=8080
RECEIVING_ADDRESS=
FACILITATOR_URL=

# Trust-proxy setting passed to Express (`app.set('trust proxy', ...)`).
# REQUIRED when running behind a TLS-terminating reverse proxy such as Caddy
# or nginx — otherwise `req.protocol` returns "http" and the x402 resource
# URL gets indexed by the CDP Bazaar under the wrong origin.
# Accepted values: "true", "false", an integer hop count, or a subnet list.
# Defaults (when unset) to "loopback, linklocal, uniquelocal" so a sibling
# Caddy container on a docker network is trusted automatically.
TRUST_PROXY=

# Optional: Coinbase CDP x402 facilitator authentication.
# If both CDP_API_KEY_ID and a private key are set, the oracle will
# use the CDP facilitator instead of the generic FACILITATOR_URL.
CDP_API_KEY_ID=
CDP_API_KEY_PRIVATE_KEY=

PRICE_REPORT=0.01
MCP_BLOCKSCOUT_CMD=
CACHE_TTL_MS=45000
